# Copy this file to .env and fill in your values before running install.sh
# cp .env.example .env

GIT_USER_NAME=
GIT_USER_EMAIL=

# Notion: create an integration at https://www.notion.so/profile/integrations
# then share the pages/databases you want Claude to access with the integration
NOTION_API_TOKEN=

# Linear: generate an API key at https://linear.app/settings/api
LINEAR_API_KEY=

# CleanShot: find your activation key in CleanShot preferences
CLEANSHOT_ACTIVATION_KEY=

# Gmail (personal) MCP — no env var needed, just drop the OAuth Desktop client JSON
# at ./gmail-oauth.keys.json (gitignored). Setup steps:
# 1. Create project + enable Gmail API at https://console.cloud.google.com/
# 2. APIs & Services > Credentials > Create OAuth client ID > Desktop app
# 3. Download JSON, rename to ./gmail-oauth.keys.json at the repo root
# 4. After install.sh registers the MCP, run once to authorize in the browser:
#    npx -y @gongrzhe/server-gmail-autoauth-mcp@1.1.11 auth
